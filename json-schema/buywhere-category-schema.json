{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://api.buywhere.ai/schema/category.json",
  "title": "BuyWhere Category",
  "type": "object",
  "required": ["slug", "name"],
  "properties": {
    "slug": { "type": "string" },
    "name": { "type": "string" },
    "product_count": { "type": "integer", "minimum": 0 },
    "parent_slug": { "type": ["string", "null"] }
  }
}
